{
  "name": "youtube-keystrokes-blocker",
  "version": "5.0.0",
  "type": "module",
  "description": "Control YouTube keyboard shortcuts with fine-grained settings. Block distracting hotkeys while keeping the ones you need.",
  "main": "disable-yt-hotkeys.user.js",
  "scripts": {
    "build": "node scripts/build.js",
    "build:chrome": "node scripts/build.js --browser chrome",
    "build:firefox": "node scripts/build.js --browser firefox",
    "dev": "node scripts/build.js --dev",
    "dev:chrome": "node scripts/build.js --browser chrome --dev",
    "dev:firefox": "node scripts/build.js --browser firefox --dev",
    "version:patch": "node scripts/update-version.js --type patch",
    "version:minor": "node scripts/update-version.js --type minor",
    "version:major": "node scripts/update-version.js --type major",
    "clean": "node -e \"import('fs').then(({default:fs})=>fs.rmSync('build',{recursive:true,force:true}))\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Life-Experimentalist/Youtube-Keystrokes-Blocker.git"
  },
  "keywords": [
    "youtube",
    "userscript",
    "tampermonkey",
    "greasemonkey",
    "hotkeys",
    "keyboard-shortcuts",
    "productivity",
    "accessibility"
  ],
  "author": {
    "name": "VKrishna04",
    "email": "hello@vkrishna04.me",
    "url": "https://vkrishna04.me"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Life-Experimentalist/Youtube-Keystrokes-Blocker/issues"
  },
  "homepage": "https://yt-hotkeys.vkrishna04.me/",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "sharp": "^0.34.1"
  },
  "dependencies": {}
}
